	email {$ACME_EMAIL:admin@continuoushq.com}
}

{$SITE_HOSTS} {
	encode zstd gzip

	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}

	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	reverse_proxy app:3000
}
