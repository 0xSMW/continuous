POSTGRES_DB=continuous
POSTGRES_USER=continuous
POSTGRES_PASSWORD=replace-with-a-long-random-secret
DATABASE_URL=postgresql://continuous:replace-with-a-url-safe-secret@db:5432/continuous

APP_ENV=production
APP_URL=http://45.55.53.92

# First deploy serves plain HTTP by IP. Switch to continuoushq.com after DNS points at the droplet.
SITE_HOSTS=http://:80
ACME_EMAIL=admin@continuoushq.com

APP_IMAGE=continuous-app
APP_TAG=local
REVENUE_WORKER_RUN_ENABLED=true
# Required for operator snapshot reads and HTTP worker runs.
# REVENUE_WORKER_RUN_TOKEN=replace-with-a-long-random-secret
