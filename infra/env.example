POSTGRES_DB=continuous
POSTGRES_USER=continuous
POSTGRES_PASSWORD=
DATABASE_URL=

APP_ENV=production
APP_URL=https://continuoushq.com

# Caddy site hosts. Keep a space after each comma.
SITE_HOSTS=continuoushq.com, getcontinuous.app
ACME_EMAIL=admin@continuoushq.com

APP_IMAGE=continuous-app
APP_TAG=local
WORKER_RUN_ENABLED=true
# Bootstrap-only secret used to mint or rotate route-scoped tokens on a fresh host.
# Steady-state auth should use CONTROL_PLANE_TOKENS_JSON or CONTROL_PLANE_TOKEN_CATALOG_B64.
WORKER_RUN_TOKEN=
WORKER_OPERATOR_EMAIL=owner@continuoushq.com
# Comma-delimited allowlists enforced by /worker, /core, and /workflow.
CONTROL_PLANE_ALLOWED_TENANTS=continuous-demo
CONTROL_PLANE_ALLOWED_WORKER_ROLES=revenue_operations,owner_chief_of_staff,dispatch_operations,finance_operations,workforce_operations,compliance_operations,systems_operations
# Production control-plane catalogs must use tokenSha256 entries, not raw tokens.
CONTROL_PLANE_TOKENS_JSON=
CONTROL_PLANE_TOKEN_CATALOG_B64=

# Optional scheduled off-host Postgres dump retention.
BACKUP_OBJECT_STORAGE_ENABLED=false
BACKUP_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=nyc3
BACKUP_S3_PREFIX=postgres
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
