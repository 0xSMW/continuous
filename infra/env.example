POSTGRES_DB=continuous
POSTGRES_USER=continuous
POSTGRES_PASSWORD=replace-with-a-long-random-secret
DATABASE_URL=postgresql://continuous:replace-with-a-url-safe-secret@db:5432/continuous

APP_ENV=production
APP_URL=http://your-droplet-ip

# Initial IP-only HTTP.
SITE_HOSTS=http://:80

# Later, after continuoushq.com DNS points at the droplet:
# SITE_HOSTS=continuoushq.com,www.continuoushq.com
ACME_EMAIL=admin@continuoushq.com

APP_IMAGE=continuous-app
APP_TAG=local
