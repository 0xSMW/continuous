{
  "name": "continuous",
  "version": "0.1.0",
  "private": false,
  "description": "Open source worker platform core for SMB operating flows.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:eval": "vitest run src/worker/evals.test.ts src/worker/revenue.integration.test.ts",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "ops:backup-check": "./scripts/check-backup-age.sh",
    "ops:backup-object-check": "bun scripts/s3-backup-object.ts --check-latest",
    "ops:backup-schedule": "./scripts/install-backup-timer.sh",
    "ops:observability-check": "./scripts/check-observability.sh",
    "ops:observability-schedule": "./scripts/install-observability-timer.sh",
    "ops:production-readiness-check": "./scripts/check-production-readiness.sh",
    "ops:non-root-access": "./scripts/install-non-root-access.sh",
    "ops:recovery-drill": "./scripts/recovery-drill.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "worker:tool": "bun src/worker/run-tool.ts",
    "app-server:help": "codex app-server --help",
    "app-server:worker-tools": "bun src/worker/run-app-server-tool.ts",
    "app-server:generate-ts": "codex app-server generate-ts --out generated/app-server/ts",
    "app-server:generate-json-schema": "codex app-server generate-json-schema --out generated/app-server/schema"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "pg": "8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@types/node": "25.9.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
