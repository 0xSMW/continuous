APP_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=
POSTGRES_DB=continuous
POSTGRES_USER=continuous
POSTGRES_PASSWORD=
NEXT_TELEMETRY_DISABLED=1
WORKER_RUN_ENABLED=false
# Required before enabling side-effecting worker commands and operator worker/core reads.
WORKER_RUN_TOKEN=
WORKER_OPERATOR_EMAIL=owner@continuoushq.com
# Optional comma-delimited allowlists for the shared operator token.
CONTROL_PLANE_ALLOWED_TENANTS=continuous-demo
CONTROL_PLANE_ALLOWED_WORKER_ROLES=revenue_operations,owner_chief_of_staff
# Optional scoped hashed token catalogs. Prefer the base64 form for deployment env files.
CONTROL_PLANE_TOKENS_JSON=
CONTROL_PLANE_TOKEN_CATALOG_B64=
WORKER_SCHEDULER_ENABLED=false
WORKER_SCHEDULER_BASE_URL=http://app:3000
WORKER_SCHEDULER_TENANT_SLUG=continuous-demo
WORKER_SCHEDULER_INTERVAL_MS=60000
WORKER_SCHEDULER_WORKFLOW_LIMIT=10
WORKER_SCHEDULER_ADAPTER_LIMIT=25
WORKER_SCHEDULER_LEAD_POLL_LIMIT=5
WORKER_SCHEDULER_WORKFLOW_LEASE_MS=300000
